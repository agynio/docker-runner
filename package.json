{
  "name": "@agyn/docker-runner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx src/service/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/service/main.js",
    "lint": "eslint .",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.config.e2e.ts",
    "proto:generate": "buf generate buf.build/agynio/api"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.7",
    "@bufbuild/protobuf": "^2.11.0",
    "@grpc/grpc-js": "^1.12.2",
    "dockerode": "^4.0.8",
    "dotenv": "^17.2.2",
    "zod": "^4.1.9"
  },
  "devDependencies": {
    "@bufbuild/protoc-gen-es": "^2.11.0",
    "@types/dockerode": "^3.3.44",
    "@types/node": "^24.5.1",
    "eslint": "^9.13.0",
    "tsx": "^4.20.5",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.8.1",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.5.0"
}
